{
  "name": "inox",
  "version": "0.4.0",
  "description": "The Inox programming language.",
  "type": "module",
  "main": "builds/inox.js",
  "bin": {
    "inox": "bin/inox.js"
  },
  "directories": {
    "lib": "lib",
    "builds": "builds",
    "test": "test"
  },
  "scripts": {
    "build": "tsc",
    "build:src": "tsc -p tsconfig.src.json",
    "run": "tsc && node --enable-source-maps builds/inox.js",
    "replit": "tsc&& node builds/inox.js",
    "serve": "node bin/inox-serve.js",
    "test:serve": "node scripts/test-inox-serve.js",
    "test:retrieval": "node scripts/test-retrieval-batch.js",
    "test:continuations": "node scripts/test-serve-continuations.js",
    "bench:serve": "node scripts/bench-inox-serve.js",
    "test:session": "node scripts/test-session-packets.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virteal/Inox.git"
  },
  "keywords": [
    "wasm"
  ],
  "author": "Jean Hugues Noel ROBERT",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/virteal/Inox/issues"
  },
  "homepage": "https://github.com/virteal/Inox#readme",
  "dependencies": {
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.1.1"
  }
}
